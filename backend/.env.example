# Local database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mydatabase

# Test database
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/testdatabase

# Secret keys
ACCESS_SECRET_KEY=change_me_access_secret_key_at_least_32_chars
RESET_PASSWORD_SECRET_KEY=change_me_reset_password_secret_at_least_32_chars
VERIFICATION_SECRET_KEY=change_me_verification_secret_at_least_32_chars

# OpenAPI generated file output path (writes the schema where the frontend
# generator reads it from — see frontend/openapi-ts.config.ts).
OPENAPI_OUTPUT_FILE=../frontend/openapi.json

# Localhost Email configuration
MAIL_USERNAME=test
MAIL_PASSWORD=test
MAIL_FROM=test@test.com
MAIL_PORT=1025
MAIL_SERVER=localhost
MAIL_STARTTLS=False
MAIL_SSL_TLS=False
USE_CREDENTIALS=False

# Frontend (React + Vite dev server)
FRONTEND_URL=http://localhost:5173

# CORS (Allow all origins for development; adjust this to restrict origins in production deployments)
# For development:
CORS_ORIGINS=["http://localhost:5173"]
# For production, replace with your actual domain:
# CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# Environment (development, staging, production)
ENVIRONMENT=development

# OPENAPI (Uncomment the line below to disable the /docs and openapi.json urls)
# OPENAPI_URL=""

# GOOGLE_OAUTH
GOOGLE_OAUTH_ENABLED=False
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Rate limiting (slowapi). Set RATE_LIMIT_ENABLED=False to turn it off.
RATE_LIMIT_ENABLED=True
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_REGISTER=20/minute

# Error tracking (Sentry). Leave SENTRY_DSN empty to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Database connection pool (per worker)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=True

# Production server worker count (used by prestart.sh / Dockerfile.prod)
WEB_CONCURRENCY=2
