# Base URL of the FastAPI backend. Vite inlines VITE_* vars at build time and
# exposes them to the browser via import.meta.env.
VITE_API_BASE_URL=http://localhost:8000

# Enable the Google OAuth button when backend GOOGLE_OAUTH_ENABLED=True
VITE_GOOGLE_OAUTH_ENABLED=false

# Sentry DSN for frontend error tracking (leave empty to disable)
VITE_SENTRY_DSN=

# OpenAPI generated file name (relative to the frontend directory).
# Read by watcher.js to regenerate the typed client on schema changes.
OPENAPI_OUTPUT_FILE=openapi.json
